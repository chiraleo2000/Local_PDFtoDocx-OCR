# ============================================
# PDF OCR Service — Environment Configuration (Example)
# v0.5.0  |  Strict engine policy: Thai → Thai-TrOCR, other → PaddleOCR
# ============================================
# Copy this file to .env and adjust values for your setup.

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=7870
SHARE_GRADIO=false
MAX_FILE_SIZE_MB=200

# --- OCR Engine (v3.0 strict policy) ---
# auto (default): Thai pages  -> Thai-TrOCR (line-level, per-line positions)
#                 other langs -> PaddleOCR (PP-OCRv5)
# Naming a specific engine runs that engine ONLY (no silent fallback):
#   thai_trocr | paddleocr | easyocr | tesseract | typhoon
OCR_ENGINE=auto

# Thai TrOCR — fine-tuned transformer for Thai characters (most accurate Thai OCR)
# Set to 1 to skip pre-loading at startup; the model still loads lazily
# on the first Thai page.
DISABLE_TROCR_PRELOAD=0

# --- GPU ---
# Set USE_GPU=true if you have an NVIDIA GPU with CUDA — significantly faster
ACCELERATOR=cpu
USE_GPU=false
CUDA_DEVICE=0

# ONNX Runtime providers for Thai-TrOCR ONNX, in priority order.
# CPU: CPUExecutionProvider
# NVIDIA GPU: CUDAExecutionProvider,CPUExecutionProvider
# Intel OpenVINO/NPU experimental: OpenVINOExecutionProvider,CPUExecutionProvider
ONNX_PROVIDERS=CPUExecutionProvider

# --- Languages ---
# Comma/plus-separated. Supported: eng tha chi_sim chi_tra jpn kor ara
LANGUAGES=tha+eng

# --- Layout Detection ---
# LAYOUT_BACKEND: docling (default) = Docling layout + TableFormer
#                 yolo    = DocLayout-YOLO rollback
LAYOUT_BACKEND=docling
DOCLING_USE_LOCALOCR_PLUGIN=1
DOCLING_IMAGES_SCALE=2.0

# YOLO (used when LAYOUT_BACKEND=yolo or Docling unavailable)
# YOLO_CONFIDENCE: 0.25-0.35 recommended — lower = more detections but more noise
#   0.15 is too permissive (false positives crowd out real tables)
#   0.30 is the model default; 0.25 catches slightly more tables without much noise
YOLO_CONFIDENCE=0.25
# YOLO_NMS: IoU threshold for non-maximum suppression — lower = less overlap allowed
YOLO_NMS=0.40

# --- Table Detection & Extraction ---
TABLE_DETECTION=true
# TABLE_ENGINE: paddleocr = PPStructure (best for complex tables, requires paddleocr)
#               opencv    = pure CV grid detection (fast fallback, always available)
# paddleocr automatically falls back to opencv if PPStructure fails
TABLE_ENGINE=paddleocr

# --- Image Extraction ---
IMAGE_EXTRACTION=true
# Minimum pixel area for a detected region to be saved as a figure (filters noise)
IMAGE_MIN_AREA=4000

# --- Quality Preset ---
# accurate = 10× render (720 DPI — best OCR + layout fidelity)
# balanced = 7.5× render (540 DPI)
# fast     = 5×  render (360 DPI — quicker preview)
QUALITY_PRESET=accurate
# Optional hard override for render scale (1.0–20.0). Empty = use preset.
# RENDER_DPI_SCALE=10.0

# --- Multi-CPU / multi-user parallelism ---
# 0 or blank = auto from host/container CPU count
# MAX_CONCURRENT_JOBS = how many users can convert PDFs at the same time
# PAGE_WORKERS        = parallel pages inside one PDF
# MODEL_SLOTS         = concurrent OCR inferences (shared across jobs)
MAX_CONCURRENT_JOBS=0
PAGE_WORKERS=0
MODEL_SLOTS=0
QUEUE_MAX_SIZE=64
# Keep BLAS/OpenMP thin so many workers can run without thrashing
OMP_NUM_THREADS=1
TORCH_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1

# --- Image enhancement ---
# Enhance cropped figures/logos (CLAHE + mild sharpen) before export
ENHANCE_IMAGES=true
# Hard adaptive binarise for OCR (OFF by default — hurts Thai-TrOCR/Paddle)
ENHANCE_BINARIZE=0
# Snap every line/figure/table coordinate to this pixel grid (1 = exact)
PIXEL_GRID=1

# DocLayout-YOLO inference size (higher = better small-region recall)
YOLO_IMGSZ=1600

# --- History ---
HISTORY_RETENTION_DAYS=30

# --- Correction & Auto-Retrain ---
CORRECTION_DATA_DIR=./correction_data
RETRAIN_INTERVAL=100

# DOCX layout mode:
#   absolute (default) = every OCR line snapped to the page pixel grid and
#              placed at its exact position (text frames, floating tables,
#              figures) mirroring the scanned page 1:1
#   flow     = continuous Word-style document — flowing paragraphs
#              (no text boxes) that keep alignment, indentation, font sizes,
#              with tables/figures inline in reading order
LAYOUT_MODE=absolute

# Force OCR on every page, even when the PDF has an embedded text layer.
# Pages with broken text layers (e.g. Thai glyphs without Unicode mapping)
# are auto-detected and OCRed regardless of this setting.
FORCE_OCR=false

# ── Typhoon OCR (SCB10X, cloud/self-hosted) — OPTIONAL, opt-in only ──
# Not part of the default pipeline. Set OCR_ENGINE=typhoon to use it. Needs ONE of:
#   TYPHOON_OCR_API_KEY  — key from https://playground.opentyphoon.ai
#   TYPHOON_BASE_URL     — self-hosted vLLM/Ollama endpoint (e.g. http://loca